    {
      "type": "rectangle",
      "id": "ZbylmDtxs_0_1Zt3S0cah",
      "x": 1032.3441554356389,
      "y": 852.9861432013247,
      "width": 1048.1086164096525,
      "height": 870,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
