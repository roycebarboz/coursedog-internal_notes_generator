      "link": null,
      "locked": false,
      "fontSize": 16,
      "fontFamily": 1,
      "text": "Website looks up the events which have Setup and calculates:\n- Setup time\n- Reservation number (with the help of VENUE CODES)\n- VENUE (with the help of Setup label dictionary)\n- Setup instruction: already present → use that; if not → use Resources Section\n- Breakdown time",
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "auto-step4-rect",
      "originalText": "Website looks up the events which have Setup and calculates:\n- Setup time\n- Reservation number (with the help of VENUE CODES)\n- VENUE (with the help of Setup label dictionary)\n- Setup instruction: already present → use that; if not → use Resources Section\n- Breakdown time",
      "autoResize": false,
      "lineHeight": 1.25
    },
