    {
      "type": "rectangle",
      "id": "heIUXKso-pp7WqL5i7Iro",
      "x": 3686.9166505613366,
      "y": 619.7208850486613,
      "width": 1308.8921867001702,
      "height": 1085,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#add8e6",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
