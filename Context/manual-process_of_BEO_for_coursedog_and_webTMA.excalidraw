      "version": 739,
      "versionNonce": 208258882,
      "isDeleted": false,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [
        {
          "type": "text",
          "id": "Oz-bAiT0jE_x-305hDdK4"
